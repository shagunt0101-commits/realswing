# RealSwing Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# 9Router (free AI routing for trade decisions)
# Get your key: http://localhost:20128 → Endpoint tab
NINE_ROUTER_API_KEY=9r_your_key_here

# 9Router base URL (default: http://localhost:20128/v1)
NINE_ROUTER_BASE=http://localhost:20128/v1

# 9Router model to use
# Options: kr/claude-sonnet-4-5 (Kiro free), cc/claude-sonnet-4-6 (Claude Code),
#          of/chatgpt-4o-latest (OpenCode Free), glm/glm-4-flash (ultra cheap)
NINE_ROUTER_MODEL=kr/claude-sonnet-4-5

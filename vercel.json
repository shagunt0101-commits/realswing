{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://realswing-backend.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_BASE": "https://realswing-backend.onrender.com",
    "VITE_ORCH_BASE": "https://realswing-orch.onrender.com"
  }
}
